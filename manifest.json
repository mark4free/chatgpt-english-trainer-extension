{
  "manifest_version": 3,
  "name": "AI English Trainer",
  "version": "0.2.0",
  "description": "Add English learning controls to ChatGPT.",
  "permissions": [
  "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}
